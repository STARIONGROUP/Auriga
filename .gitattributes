# Generated code is emitted with LF line endings by the code generator and committed as-is. Pin it to
# LF so it is not smudged to CRLF on Windows checkouts; that keeps the committed output byte-identical
# across platforms and lets the CI drift guard (regenerate + git diff) run cleanly everywhere.
Auriga/AutoGenClasses/**/*.cs        text eol=lf
Auriga/AutoGenInterfaces/**/*.cs     text eol=lf
Auriga/AutoGenEnumeration/**/*.cs    text eol=lf
Auriga.Xmi/AutoGenXmiReaders/**/*.cs text eol=lf
Auriga.Xmi/AutoGenXmiWriters/**/*.cs text eol=lf
Auriga.Sirius/AutoGenClasses/**/*.cs        text eol=lf
Auriga.Sirius/AutoGenInterfaces/**/*.cs     text eol=lf
Auriga.Sirius/AutoGenEnumeration/**/*.cs    text eol=lf
Auriga.Sirius.Xmi/AutoGenXmiReaders/**/*.cs text eol=lf
Auriga.Sirius.Xmi/AutoGenXmiWriters/**/*.cs text eol=lf

# The vendored Sirius/GMF metamodels are read verbatim by the generator; pin them to LF so a Windows
# checkout does not smudge them to CRLF and perturb local regeneration.
resources/ecore-sirius/*.ecore text eol=lf

# The golden files mirror generated output and are compared byte-for-byte, so pin them to LF too.
Auriga.CodeGenerator.Tests/Expected/**/*.cs text eol=lf

# The templates drive that output; keep them LF so a Windows checkout does not perturb generation.
Auriga.CodeGenerator/Templates/*.hbs text eol=lf

# Shell scripts and the docs image files must stay LF; CRLF breaks bash and the nginx entrypoint.
*.sh                 text eol=lf
HtmlDocs/Dockerfile  text eol=lf
HtmlDocs/nginx.conf  text eol=lf
