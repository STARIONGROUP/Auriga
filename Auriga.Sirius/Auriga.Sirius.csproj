<?xml version="1.0" encoding="utf-8"?>

<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.1</TargetFramework>
        <LangVersion>10.0</LangVersion>
        <Title>Auriga.Sirius</Title>
        <Version>1.0.0</Version>
        <Description>Auriga.Sirius contains the Sirius and GMF diagram/representation object model: the C# implementation of the Sirius viewpoint, diagram, sequence and table metamodels plus the GMF notation metamodel, generated from the vendored Sirius/GMF Ecore metamodels. It is the object model behind the Eclipse Capella .aird diagram files.</Description>
        <PackageId>Auriga.Sirius</PackageId>
        <GeneratePackageOnBuild>False</GeneratePackageOnBuild>
        <AssemblyTitle>Auriga.Sirius</AssemblyTitle>
        <PackageTags>Capella Sirius GMF Aird Diagram Ecore MBSE modeltopia</PackageTags>
        <PackageReleaseNotes>
            [Add] Sirius/GMF object model; closes #52
        </PackageReleaseNotes>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Auriga\Auriga.csproj" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="$(MSBuildProjectName).Tests" />
    </ItemGroup>

</Project>
